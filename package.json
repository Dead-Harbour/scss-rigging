{
    "author": "ChrisOfNormandy",
    "description": "A collection of styles to make routine designs simpler.",
    "license": "MIT",
    "name": "@dead-harbour/scss-rigging",
    "packageManager": "yarn@4.17.0",
    "type": "module",
    "version": "1.0.3",
    "files": [
        "scss",
        "dist"
    ],
    "exports": {
        "./*": "./scss/*",
        "./config": {
            "import": "./dist/config.js",
            "require": "./dist/config.js",
            "types": "./dist/config.d.ts"
        },
        "./themes": {
            "import": "./dist/lib.js",
            "require": "./dist/lib.js",
            "types": "./dist/lib.d.ts"
        }
    },
    "devDependencies": {
        "@dead-harbour/shipshape": "^1.0.2",
        "@stylistic/stylelint-config": "^5.0.0",
        "@stylistic/stylelint-plugin": "^5.2.0",
        "@types/node": "^26.0.1",
        "eslint": "^10.5.0",
        "knip": "^6.20.0",
        "postcss": "^8.5.15",
        "sass": "^1.101.0",
        "stylelint": "^17.14.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "sass": ">=1.87"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "lint": "eslint ./lib --fix && yarn stylelint '**/*.scss'",
        "sanity": "yarn typecheck && yarn lint && yarn knip",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
