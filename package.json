{
    "author": "ChrisOfNormandy",
    "description": "A collection of styles to make routine designs simpler.",
    "license": "MIT",
    "name": "@syren-dev-tech/confetti",
    "packageManager": "yarn@4.11.0",
    "type": "module",
    "version": "0.0.0",
    "files": [
        "scss",
        "dist"
    ],
    "exports": {
        "./*": "./scss/*",
        "./config": {
            "import": "./dist/config.js",
            "require": "./dist/config.js",
            "types": "./dist/config.d.ts"
        },
        "./themes": {
            "import": "./dist/themes.js",
            "require": "./dist/themes.js",
            "types": "./dist/themes.d.ts"
        }
    },
    "devDependencies": {
        "@eslint/js": "^9.26.0",
        "@syren-dev-tech/concauses": "^0.1.0",
        "@types/node": "^22.15.17",
        "eslint": "^9.26.0",
        "knip": "^5.55.1",
        "sass": "^1.87.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.0"
    },
    "peerDependencies": {
        "sass": ">=1.83"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "lint": "eslint ./lib --fix",
        "sanity": "yarn typecheck && yarn lint && yarn knip",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
